<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>🎵 LARP Music</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --purple:#7F77DD;--purple-d:#3C3489;--purple-bg:rgba(127,119,221,0.12);
      --teal:#1D9E75;--teal-bg:rgba(29,158,117,0.12);
      --coral:#D85A30;--coral-bg:rgba(216,90,48,0.12);
      --bg:#0e0e16;--surf:#1a1a2e;--surf2:#12121f;
      --text:#e8e8f0;--muted:#8888a8;--border:rgba(255,255,255,0.08);
      --r:10px;
    }
    body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;min-height:100vh;display:flex;flex-direction:column}
    header{background:var(--surf);border-bottom:1px solid var(--border);padding:.85rem 1.25rem;display:flex;align-items:center;justify-content:space-between}
    .logo{font-size:1.1rem;font-weight:700;color:var(--purple)}.logo span{color:var(--text)}
    #badge{font-size:.72rem;padding:3px 10px;border-radius:20px;background:var(--teal-bg);color:#5DCAA5;border:1px solid rgba(93,202,165,.3)}
    #badge.off{background:var(--coral-bg);color:#F0997B;border-color:rgba(216,90,48,.3)}
    nav{display:flex;background:var(--surf);border-bottom:1px solid var(--border)}
    nav button{flex:1;padding:.7rem;background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);cursor:pointer;font-size:.88rem;transition:all .2s}
    nav button.on{color:var(--purple);border-bottom-color:var(--purple)}
    .view{display:none;flex:1;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1rem}
    .view.on{display:flex}

    /* ── PLAYER ── */
    .art{width:150px;height:150px;border-radius:14px;background:var(--surf);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:3.5rem;margin:0 auto 1.1rem;transition:box-shadow .4s,border-color .4s}
    .art.play{border-color:var(--purple);box-shadow:0 0 28px rgba(127,119,221,.35);animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
    #tname{font-size:1rem;font-weight:600;text-align:center;margin-bottom:.25rem}
    #tstatus{font-size:.82rem;color:var(--muted);text-align:center;margin-bottom:1.25rem}
    .pbar{width:100%;max-width:380px}
    .prog-wrap{height:4px;background:rgba(255,255,255,.1);border-radius:2px;margin-bottom:.4rem}
    #prog{height:100%;width:0%;background:var(--purple);border-radius:2px;transition:width .8s linear}
    .trow{display:flex;justify-content:space-between;font-size:.72rem;color:var(--muted)}

    /* ── ADMIN GATE ── */
    .gate{width:100%;max-width:400px;background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:1.4rem}
    .gate h2{font-size:.95rem;color:var(--purple);margin-bottom:1rem}
    .f{margin-bottom:.9rem}
    .f label{display:block;font-size:.75rem;color:var(--muted);margin-bottom:.35rem}
    .f input{width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:.55rem .75rem;font-size:.88rem;outline:none;transition:border-color .2s}
    .f input:focus{border-color:var(--purple)}
    .err{color:#F0997B;font-size:.78rem;margin-top:.4rem;min-height:1.1em}

    /* ── ADMIN PANEL ── */
    #apanel{width:100%;max-width:500px;display:none;flex-direction:column;gap:1rem}
    #apanel.on{display:flex}
    .sec{background:var(--surf);border:1px solid var(--border);border-radius:var(--r);padding:1.1rem}
    .sec h3{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.9rem}
    .brow{display:flex;gap:.6rem;flex-wrap:wrap}

    /* Boutons */
    .btn{display:inline-flex;align-items:center;gap:5px;padding:.5rem 1rem;border-radius:7px;border:none;cursor:pointer;font-size:.85rem;font-weight:500;transition:opacity .15s,transform .1s}
    .btn:active{transform:scale(.97)}.btn:disabled{opacity:.35;cursor:not-allowed}
    .bp{background:var(--purple);color:#fff}
    .bt{background:var(--teal);color:#fff}
    .bc{background:var(--coral);color:#fff}
    .bg{background:rgba(255,255,255,.1);color:var(--text)}

    /* Zone de dépôt */
    #dropzone{border:2px dashed rgba(127,119,221,.4);border-radius:var(--r);padding:1.5rem;text-align:center;cursor:pointer;transition:all .2s;background:rgba(127,119,221,.04)}
    #dropzone:hover,#dropzone.drag{border-color:var(--purple);background:var(--purple-bg)}
    #dropzone p{font-size:.85rem;color:var(--muted);margin-bottom:.5rem}
    #dropzone strong{color:var(--purple)}
    #file-input{display:none}

    /* Barre de progression upload */
    #upload-progress{display:none;margin-top:.75rem}
    .upbar-wrap{height:6px;background:rgba(255,255,255,.1);border-radius:3px;overflow:hidden;margin-bottom:.4rem}
    #upbar{height:100%;width:0%;background:var(--purple);border-radius:3px;transition:width .2s}
    #up-label{font-size:.78rem;color:var(--muted);text-align:center}

    /* Liste pistes */
    #track-list{display:flex;flex-direction:column;gap:.5rem;max-height:260px;overflow-y:auto}
    .track-item{display:flex;align-items:center;gap:.6rem;padding:.6rem .75rem;background:var(--surf2);border-radius:7px;border:1px solid var(--border);transition:border-color .2s}
    .track-item:hover{border-color:rgba(127,119,221,.4)}
    .track-item.active{border-color:var(--purple);background:var(--purple-bg)}
    .track-item .tinfo{flex:1;min-width:0}
    .track-item .tinfo strong{display:block;font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .track-item .tinfo span{font-size:.72rem;color:var(--muted)}
    .track-item .tbtn{display:flex;gap:.35rem;flex-shrink:0}
    .tbtn button{padding:.3rem .6rem;font-size:.78rem;border-radius:5px;border:none;cursor:pointer;font-weight:500}
    .tbtn .tplay{background:var(--purple-bg);color:var(--purple)}
    .tbtn .tdel{background:var(--coral-bg);color:var(--coral)}
    .tbtn button:hover{opacity:.8}

    /* Seek / vol */
    .srow{display:flex;align-items:center;gap:.6rem}
    .srow input[type=range]{flex:1}
    #connected{font-size:.82rem;color:#5DCAA5;margin-top:.3rem}
    audio{display:none}
  </style>
</head>
<body>

<header>
  <div class="logo">🎵 LARP <span>Music</span></div>
  <div id="badge" class="off">Connexion…</div>
</header>

<nav>
  <button class="on" onclick="tab('player')">🎧 Écouter</button>
  <button onclick="tab('admin')">🎛️ Admin</button>
</nav>

<!-- VUE JOUEUR -->
<div id="view-player" class="view on">
  <div class="art" id="art">🎵</div>
  <div id="tname">En attente de l'admin…</div>
  <div id="tstatus">Connecté — musique à venir</div>
  <div class="pbar">
    <div class="prog-wrap"><div id="prog"></div></div>
    <div class="trow"><span id="tc">0:00</span><span id="tt">0:00</span></div>
  </div>
  <audio id="ap" preload="auto"></audio>
</div>

<!-- VUE ADMIN -->
<div id="view-admin" class="view">
  <div class="gate" id="gate">
    <h2>🔐 Accès administrateur</h2>
    <div class="f">
      <label>Mot de passe</label>
      <input type="password" id="apass" placeholder="Mot de passe admin" onkeydown="if(event.key==='Enter')unlock()"/>
    </div>
    <button class="btn bp" onclick="unlock()">Déverrouiller</button>
    <div class="err" id="aerr"></div>
  </div>

  <div id="apanel">

    <!-- Upload -->
    <div class="sec">
      <h3>📁 Mes pistes</h3>
      <div id="dropzone" onclick="document.getElementById('file-input').click()"
           ondragover="ev(event,'drag')" ondragleave="ev(event,'')" ondrop="drop(event)">
        <p>Glisse ton fichier MP3 ici</p>
        <p><strong>ou clique pour choisir</strong></p>
        <p style="font-size:.72rem;color:var(--muted);margin-top:.3rem">MP3, OGG, WAV, FLAC — max 150 Mo</p>
      </div>
      <input type="file" id="file-input" accept="audio/*" onchange="uploadFile(this.files[0])"/>
      <div id="upload-progress">
        <div class="upbar-wrap"><div id="upbar"></div></div>
        <div id="up-label">Upload en cours…</div>
      </div>
      <div class="err" id="uperr"></div>
      <div id="track-list" style="margin-top:.9rem"></div>
    </div>

    <!-- Contrôles -->
    <div class="sec">
      <h3>▶ Contrôles de lecture</h3>
      <div style="font-size:.82rem;color:var(--muted);margin-bottom:.75rem" id="now-playing">Aucune piste sélectionnée</div>
      <div class="brow">
        <button class="btn bt" onclick="adminPlay()">▶ Play</button>
        <button class="btn bg" onclick="adminPause()">⏸ Pause</button>
        <button class="btn bc" onclick="adminStop()">⏹ Stop</button>
      </div>
    </div>

    <!-- Seek -->
    <div class="sec">
      <h3>⏩ Position</h3>
      <div class="srow">
        <span style="font-size:.75rem;color:var(--muted)">0:00</span>
        <input type="range" id="seekbar" min="0" max="300" value="0" step="1" oninput="document.getElementById('slabel').textContent=fmt(this.value)"/>
        <span style="font-size:.75rem;color:var(--muted)" id="slabel">0:00</span>
      </div>
      <button class="btn bg" style="margin-top:.5rem;font-size:.8rem" onclick="adminSeek()">Aller à cette position</button>
    </div>

    <!-- Volume -->
    <div class="sec">
      <h3>🔊 Volume</h3>
      <div class="srow">
        <span>🔈</span>
        <input type="range" id="volbar" min="0" max="1" step="0.05" value="0.8" oninput="adminVol(this.value)"/>
        <span>🔊</span>
        <span id="vlabel" style="font-size:.82rem;min-width:2.5rem">80%</span>
      </div>
    </div>

    <!-- Participants -->
    <div class="sec">
      <h3>📡 Participants</h3>
      <div id="connected">Chargement…</div>
    </div>

  </div>
</div>

<script>
const audio = document.getElementById('ap');
let ws, adminPwd = '', currentTrackUrl = '';
let progTimer;

// ── WebSocket ──────────────────────────────────
function connect() {
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  ws = new WebSocket(`${proto}://${location.host}`);
  ws.onopen = () => { setBadge(true); };
  ws.onclose = () => { setBadge(false); setTimeout(connect, 2000); };
  ws.onmessage = e => handle(JSON.parse(e.data));
}

function setBadge(ok) {
  const b = document.getElementById('badge');
  b.textContent = ok ? '● Connecté' : '● Déconnecté';
  b.className = ok ? '' : 'off';
}

function handle(msg) {
  switch(msg.type) {
    case 'sync': applyState(msg.state); break;
    case 'track_changed':
      audio.src = msg.trackUrl;
      currentTrackUrl = msg.trackUrl;
      document.getElementById('tname').textContent = msg.trackName;
      document.getElementById('tstatus').textContent = 'Piste chargée — en attente…';
      document.getElementById('art').classList.remove('play');
      setNowPlaying(msg.trackName);
      setProgress(0,0); break;
    case 'play':
      audio.currentTime = msg.currentTime + (Date.now()-msg.serverTime)/1000;
      audio.play().catch(()=>{});
      document.getElementById('tstatus').textContent = '▶ En lecture';
      document.getElementById('art').classList.add('play');
      startProg(); break;
    case 'pause':
      audio.pause(); audio.currentTime = msg.currentTime;
      document.getElementById('tstatus').textContent = '⏸ En pause';
      document.getElementById('art').classList.remove('play');
      stopProg(); break;
    case 'stop':
      audio.pause(); audio.currentTime = 0;
      document.getElementById('tstatus').textContent = '⏹ Arrêté';
      document.getElementById('art').classList.remove('play');
      setProgress(0,0); stopProg(); break;
    case 'seek':
      const lag = msg.status==='playing'?(Date.now()-msg.serverTime)/1000:0;
      audio.currentTime = msg.currentTime+lag;
      if(msg.status!=='playing') audio.pause(); break;
    case 'volume': audio.volume = msg.volume; break;
    case 'error': document.getElementById('aerr').textContent = msg.message; break;
  }
}

function applyState(s) {
  if(s.trackUrl){ audio.src=s.trackUrl; currentTrackUrl=s.trackUrl; document.getElementById('tname').textContent=s.trackName||''; }
  audio.volume = s.volume||0.8;
  if(s.status==='playing'){
    const lag=(Date.now()-(s.startedAt||Date.now()))/1000;
    audio.currentTime=(s.currentTime||0)+lag;
    audio.play().catch(()=>{});
    document.getElementById('tstatus').textContent='▶ En lecture';
    document.getElementById('art').classList.add('play');
    startProg();
  } else if(s.status==='paused'){
    audio.currentTime=s.currentTime||0;
    document.getElementById('tstatus').textContent='⏸ En pause';
  }
}

audio.onloadedmetadata = () => {
  document.getElementById('tt').textContent = fmt(audio.duration);
  document.getElementById('seekbar').max = Math.floor(audio.duration);
};

function startProg(){ stopProg(); progTimer=setInterval(()=>{ if(!isNaN(audio.duration)) setProgress(audio.currentTime,audio.duration); },500); }
function stopProg(){ clearInterval(progTimer); }
function setProgress(c,t){ const p=t?(c/t)*100:0; document.getElementById('prog').style.width=p+'%'; document.getElementById('tc').textContent=fmt(c); document.getElementById('tt').textContent=fmt(t); }
function fmt(s){ s=Math.floor(s||0); return `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`; }

// ── Admin unlock ───────────────────────────────
function unlock() {
  const p = document.getElementById('apass').value;
  if(!p){ document.getElementById('aerr').textContent='Entre le mot de passe'; return; }
  adminPwd = p;
  wsSend({ type:'volume', volume: parseFloat(document.getElementById('volbar').value) });
  document.getElementById('aerr').textContent = '';
  setTimeout(()=>{
    if(document.getElementById('aerr').textContent) return;
    document.getElementById('gate').style.display='none';
    document.getElementById('apanel').classList.add('on');
    loadTracks();
    setInterval(()=>{ fetch('/api/status').then(r=>r.json()).then(d=>{ document.getElementById('connected').textContent=`${d.clients} participant(s) connecté(s)`; }).catch(()=>{}); }, 4000);
    fetch('/api/status').then(r=>r.json()).then(d=>{ document.getElementById('connected').textContent=`${d.clients} participant(s) connecté(s)`; });
  }, 350);
}

function wsSend(obj){ if(ws&&ws.readyState===1) ws.send(JSON.stringify({...obj,password:adminPwd})); }

// ── Upload ─────────────────────────────────────
function ev(e,cls){ e.preventDefault(); document.getElementById('dropzone').className=cls?`drag`:''; }
function drop(e){ e.preventDefault(); document.getElementById('dropzone').className=''; const f=e.dataTransfer.files[0]; if(f) uploadFile(f); }

function uploadFile(file) {
  if(!file) return;
  if(file.size > 150*1024*1024){ showUpErr('Fichier trop lourd (max 150 Mo)'); return; }
  document.getElementById('uperr').textContent='';
  document.getElementById('upload-progress').style.display='block';
  document.getElementById('upbar').style.width='0%';
  document.getElementById('up-label').textContent='Upload en cours…';

  const fd = new FormData();
  fd.append('track', file);
  const xhr = new XMLHttpRequest();
  xhr.open('POST', '/api/upload');
  xhr.setRequestHeader('x-admin-password', adminPwd);
  xhr.upload.onprogress = e => {
    if(e.lengthComputable){
      const pct = Math.round(e.loaded/e.total*100);
      document.getElementById('upbar').style.width=pct+'%';
      document.getElementById('up-label').textContent=`Upload… ${pct}%`;
    }
  };
  xhr.onload = () => {
    document.getElementById('upload-progress').style.display='none';
    if(xhr.status===200){
      const d = JSON.parse(xhr.responseText);
      document.getElementById('up-label').textContent='✅ Upload réussi !';
      loadTracks();
      // Charger automatiquement la piste uploadée
      selectTrack(d.track.url, d.track.name);
    } else {
      const d = JSON.parse(xhr.responseText);
      showUpErr(d.error||'Erreur upload');
    }
  };
  xhr.onerror = () => { document.getElementById('upload-progress').style.display='none'; showUpErr('Erreur réseau'); };
  xhr.send(fd);
}

function showUpErr(msg){ document.getElementById('uperr').textContent=msg; document.getElementById('upload-progress').style.display='none'; }

// ── Liste pistes ───────────────────────────────
function loadTracks(){
  fetch('/api/tracks').then(r=>r.json()).then(tracks=>{
    const list = document.getElementById('track-list');
    if(!tracks.length){ list.innerHTML='<p style="font-size:.8rem;color:var(--muted);text-align:center;padding:.5rem">Aucune piste — uploade ton premier MP3 !</p>'; return; }
    list.innerHTML = tracks.map(t=>`
      <div class="track-item${currentTrackUrl===t.url?' active':''}" id="ti-${CSS.escape(t.filename)}">
        <div class="tinfo">
          <strong title="${t.name}">${t.name}</strong>
          <span>${(t.size/1024/1024).toFixed(1)} Mo</span>
        </div>
        <div class="tbtn">
          <button class="tplay" onclick="selectTrack('${t.url}','${t.name.replace(/'/g,"\\'")}')">▶ Choisir</button>
          <button class="tdel" onclick="deleteTrack('${t.filename}')">🗑</button>
        </div>
      </div>`).join('');
  });
}

function selectTrack(url, name){
  wsSend({ type:'set_track', trackUrl:url, trackName:name });
  currentTrackUrl = url;
  setNowPlaying(name);
  loadTracks();
}

function setNowPlaying(name){ document.getElementById('now-playing').textContent = name ? `🎵 ${name}` : 'Aucune piste sélectionnée'; }

function deleteTrack(filename){
  if(!confirm('Supprimer cette piste ?')) return;
  fetch('/api/tracks/'+encodeURIComponent(filename),{ method:'DELETE', headers:{'x-admin-password':adminPwd} })
    .then(()=>loadTracks());
}

// ── Commandes lecture ──────────────────────────
function adminPlay(){ wsSend({ type:'play', currentTime:audio.currentTime }); }
function adminPause(){ wsSend({ type:'pause' }); }
function adminStop(){ wsSend({ type:'stop' }); }
function adminSeek(){ wsSend({ type:'seek', currentTime:parseFloat(document.getElementById('seekbar').value) }); }
function adminVol(v){ document.getElementById('vlabel').textContent=Math.round(v*100)+'%'; wsSend({ type:'volume', volume:parseFloat(v) }); }

document.getElementById('seekbar').oninput = function(){ document.getElementById('slabel').textContent=fmt(this.value); };

// ── Tabs ───────────────────────────────────────
function tab(t){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('on'));
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('on'));
  document.getElementById('view-'+t).classList.add('on');
  document.querySelectorAll('nav button')[t==='player'?0:1].classList.add('on');
}

connect();
</script>
</body>
</html>
